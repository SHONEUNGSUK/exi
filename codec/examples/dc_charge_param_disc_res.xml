  <!-- Min charge current: 1 A -->
  <dc:MinimumChargeCurrent>
    <ct:Exponent>0</ct:Exponent>
    <ct:Value>1</ct:Value>
  </dc:MinimumChargeCurrent>
  <!-- Voltage range: 200–920 V -->
  <dc:MaximumVoltage>
    <ct:Exponent>0</ct:Exponent>
    <ct:Value>920</ct:Value>
  </dc:MaximumVoltage>
  <dc:MinimumVoltage>
    <ct:Exponent>0</ct:Exponent>
    <ct:Value>200</ct:Value>
