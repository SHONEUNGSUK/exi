<?xml version="1.0" encoding="UTF-8"?>
<!-- ISO 15118-20  DC_ChargeLoopReq  (V2GCI_DC)
     EV → EVSE  : Dynamic DC charge loop control request -->
<dc:DC_ChargeLoopReq xmlns:dc="urn:iso:std:iso:15118:-20:DC"
                     xmlns:ct="urn:iso:std:iso:15118:-20:CommonTypes">
  <dc:Header>
    <ct:SessionID>A1B2C3D4E5F60708</ct:SessionID>
    <ct:TimeStamp>1705312560</ct:TimeStamp>
  </dc:Header>

  <!-- Optional display parameters for EVSE HMI -->
  <dc:DisplayParameters>
    <dc:PresentSOC>62</dc:PresentSOC>
    <dc:MinimumSOC>20</dc:MinimumSOC>
    <dc:TargetSOC>80</dc:TargetSOC>
    <dc:MaximumSOC>100</dc:MaximumSOC>
    <dc:RemainingTimeToTargetSOC>1800</dc:RemainingTimeToTargetSOC>
    <dc:ChargingComplete>false</dc:ChargingComplete>
    <dc:BatteryEnergyCapacity>
      <ct:Exponent>3</ct:Exponent>
      <ct:Value>77</ct:Value>
    </dc:BatteryEnergyCapacity>
    <dc:InletHot>false</dc:InletHot>
  </dc:DisplayParameters>

  <dc:EVErrorCode>NO_ERROR</dc:EVErrorCode>
  <dc:EVRESSSOC>62</dc:EVRESSSOC>

  <!-- Energy targets  (Exponent=-3 → multiply by 0.001) -->
  <dc:EVTargetEnergyRequest>
    <ct:Exponent>3</ct:Exponent>
    <ct:Value>58</ct:Value>
  </dc:EVTargetEnergyRequest>
  <dc:EVMaximumEnergyRequest>
    <ct:Exponent>3</ct:Exponent>
    <ct:Value>77</ct:Value>
  </dc:EVMaximumEnergyRequest>
  <dc:EVMinimumEnergyRequest>
    <ct:Exponent>3</ct:Exponent>
    <ct:Value>15</ct:Value>
  </dc:EVMinimumEnergyRequest>

  <!-- Current and voltage targets -->
  <dc:EVTargetCurrent>
    <ct:Exponent>0</ct:Exponent>
    <ct:Value>125</ct:Value>
  </dc:EVTargetCurrent>
  <dc:EVTargetVoltage>
    <ct:Exponent>0</ct:Exponent>
    <ct:Value>400</ct:Value>
  </dc:EVTargetVoltage>
</dc:DC_ChargeLoopReq>
